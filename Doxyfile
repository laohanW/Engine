# Doxygen configuration for BattleFire Engine
PROJECT_NAME           = "BattleFire Engine"
OUTPUT_DIRECTORY       = docs/build
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = YES
RECURSIVE              = YES
INPUT                  = Runtime Platform README.md docs/README.md
FILE_PATTERNS          = *.h *.hpp *.c *.cpp *.md
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_METHODS  = NO
EXTRACT_ANON_NSPACES   = YES
JAVADOC_AUTOBRIEF      = YES
ALIASES                = "example=\\par Example:"
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
GENERATE_TREEVIEW      = YES
HTML_OUTPUT            = html
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = /workspace
USE_MDFILE_AS_MAINPAGE = docs/README.md
MARKDOWN_SUPPORT       = YES
